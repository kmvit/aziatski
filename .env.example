# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# Сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Старый ключ из репозитория (символ $ лучше экранировать в .env как $$ или взять в двойные кавычки):
# SECRET_KEY="django-insecure-x$5ibu@q66_$jnwcjap&43u^t^r1qjovc3%qk^yted!t@1q@72"
SECRET_KEY=django-insecure-change-me

DEBUG=True

# Через запятую, без пробелов вокруг имён хостов. Пусто = только тестовый клиент Django.
ALLOWED_HOSTS=

# База данных: SQLite (по умолчанию)
DB_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# PostgreSQL (раскомментируйте и задайте DB_ENGINE / переменные ниже)
# DB_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=aziatskiy
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
